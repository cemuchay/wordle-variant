{
  "name": "variant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "sim:bot": "npx tsx scripts/gameSimulator.ts --mode bot",
    "sim:pvp": "npx tsx scripts/gameSimulator.ts --mode pvp --mock",
    "sim:stress": "npx tsx scripts/gameSimulator.ts --mode bot --runs 100 --report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@vercel/analytics": "^2.0.1",
    "agora-rtc-sdk-ng": "^4.24.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.10.6",
    "sharp": "^0.35.2",
    "supabase": "^2.108.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.9"
  }
}
